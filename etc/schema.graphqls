
type Query {
    payuCheckoutHtml(
		quote_id: String!
		enforce_paymethod: String!
	): PayuCheckoutResponse @resolver(class: "PayUIndia\\Payu\\Model\\Resolver\\PayuCheckoutResolver")
}
type PayuCheckoutResponse {
    html: String
}
type Mutation {
    payuResponseResolver(
        event: String!
        quote_id: String!
        full_response: String
    ): PayuResponseResolverOutput @resolver(class: "PayUIndia\\Payu\\Model\\Resolver\\PayuResponseResolver")
}

type PayuResponseResolverOutput {
    success: Boolean
    message: String
    order_id: String
}